0645\u0632\u064a\u062f \u0645\u0646 \u0627\u0644\u062a\u0641\u0627\u0635\u064a\u0644 \u062d\u0648\u0644 \u0645\u062a\u0637\u0644\u0628\u0627\u062a\u0643.\n[2026-03-17 12:59:50] safouaneAI: \u0623\u0647\u0644\u0627\u064b \u0628\u0643! \u064a\u0628\u062f\u0648 \u0623\u0646\u0643 \u062a\u062a\u062d\u062f\u062b \u0639\u0646 \u0644\u0639\u0628\u0629 \u0645\u0627\u060c \u0648\u0644\u0643\u0646\u0646\u064a \u0644\u0627 \u0623\u0641\u0647\u0645 \u062a\u0645\u0627\u0645\u064b\u0627 \u0645\u0627 \u062a\u0642\u0635\u062f \u0628\u0647 \"\u0645\u062a\u062d\u062c\u0631\". \u0647\u0644 \u062a\u0642\u0635\u062f \u0644\u0639\u0628\u0629 Minecraft\u061f \u0625\u0630\u0627 \u0643\u0627\u0646 \u0630\u0644\u0643 \u0635\u062d\u064a\u062d\u064b\u0627\u060c \u064a\u0645\u0643\u0646\u0646\u064a \u0645\u0633\u0627\u0639\u062f\u062a\u0643 \u0641\u064a \u0643\u064a\u0641\u064a\u0629 \u0628\u0646\u0627\u0621 \u0633\u0643\u0646 \u062c\u062f\u064a\u062f \u0641\u064a \u0627\u0644\u0644\u0639\u0628\u0629.\n\n\u0644\u0644\u0628\u0646\u0627\u0621 \u0633\u0643\u0646 \u062c\u062f\u064a\u062f \u0641\u064a Minecraft\u060c \u064a\u0645\u0643\u0646\u0643 \u0627\u062a\u0628\u0627\u0639 \u0627\u0644\u062e\u0637\u0648\u0627\u062a \u0627\u0644\u062a\u0627\u0644\u064a\u0629:\n\n1. \u0627\u062e\u062a\u0631 \u0645\u0648\u0642\u0639\u064b\u0627 \u0645\u0646\u0627\u0633\u0628\u064b\u0627 \u0644\u0628\u0646\u0627\u0621 \u0633\u0643\u0646\u0643\u060c \u0645\u062b\u0644 \u0645\u0643\u0627\u0646 \u0628\u0627\u0644\u0642\u0631\u0628 \u0645\u0646 \u0645\u0635\u062f\u0631 \u0645\u0627\u0621 \u0623\u0648 \u0641\u064a \u0645\u0646\u0637\u0642\u0629 \u0622\u0645\u0646\u0629.\n2. \u0627\u062d\u0635\u0644 \u0639\u0644\u0649 \u0627\u0644\u0645\u0648\u0627\u062f \u0627\u0644\u0644\u0627\u0632\u0645\u0629 \u0644\u0644\u0628\u0646\u0627\u0621\u060c \u0645\u062b\u0644 \u0627\u0644\u062d\u062c\u0627\u0631\u0629 \u0623\u0648 \u0627\u0644\u062e\u0634\u0628.\n3. \u0627\u0633\u062a\u062e\u062f\u0645 \u0623\u062f\u0627\u0629 \u0627\u0644